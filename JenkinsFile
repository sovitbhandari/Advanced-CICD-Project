pipeline {
  agent {
    docker {
      image 'python:3.12-slim'  // Using official Python Docker image
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }
  environment {
    DOCKER_IMAGE = "yourdockerhubusername/python-flask-app:${BUILD_NUMBER}"
  }
  stages {
    stage('Checkout') {
      steps {
        sh 'echo Cloning Repository...'
        sh 'ls -la'
        // Uncomment and set your repo if needed
        // git branch: 'main', url: 'https://github.com/your-username/your-python-repo.git'
      }
    }
    stage('Install Dependencies') {
      steps {
        sh '''
          python3 -m venv venv
          . venv/bin/activate
          pip install --upgrade pip
          pip install -r requirements.txt
        '''
      }
    }
    stage('Lint and Test') {
      steps {
        sh '''
          . venv/bin/activate
          pip install flake8 pytest
          flake8 .
          pytest
        '''
      }
    }
    stage('Build and Push Docker Image') {
      environment {
        REGISTRY_CREDENTIALS = credentials('docker-cred')
      }
      steps {
        script {
          sh 'docker build -t ${DOCKER_IMAGE} .'
          def dockerImage = docker.image("${DOCKER_IMAGE}")
          docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
            dockerImage.push()
          }
        }
      }
    }
    stage('Deploy or Update Deployment File') {
      steps {
        sh 'echo Deployment Stage - Add your deployment steps here'
      }
    }
  }
}
